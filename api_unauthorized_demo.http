@baseUrl = http://localhost:8081

### Test Missing Token - Get All Appointments
GET {{baseUrl}}/adsweb/api/v1/appointments

### Test Missing Token - Get All Patients
GET {{baseUrl}}/adsweb/api/v1/patients

### Test Missing Token - Get All Dentists
GET {{baseUrl}}/adsweb/api/v1/dentists

### Test Missing Token - Get All Surgeries
GET {{baseUrl}}/adsweb/api/v1/surgeries

### Test Missing Token - Get All Addresses
GET {{baseUrl}}/adsweb/api/v1/addresses

### Test Missing Token - Create Patient
POST {{baseUrl}}/adsweb/api/v1/patients
Content-Type: application/json

{
	"firstName": "Test",
	"lastName": "User",
	"phoneNumber": "641-555-1234",
	"email": "test@example.com",
	"address": {
		"addressLine": "123 Main St",
		"city": "Fairfield",
		"state": "IA",
		"postalCode": "52557"
	},
	"dateOfBirth": "1990-01-01",
	"hasUnpaidBill": false
}

### Test Missing Token - Create Dentist
POST {{baseUrl}}/adsweb/api/v1/dentists
Content-Type: application/json

{
	"firstName": "Test",
	"lastName": "Dentist",
	"phoneNumber": "641-555-5678",
	"email": "testdentist@adsdental.com",
	"specialization": "General"
}

### Test Missing Token - Create Surgery
POST {{baseUrl}}/adsweb/api/v1/surgeries
Content-Type: application/json

{
	"surgeryName": "Test Surgery",
	"telephoneNumber": "641-555-9999",
	"address": {
		"addressLine": "999 Test Ave",
		"city": "Fairfield",
		"state": "IA",
		"postalCode": "52557"
	}
}

### Test Missing Token - Delete Appointment
DELETE {{baseUrl}}/adsweb/api/v1/appointment/1

### Test Missing Token - Delete Patient
DELETE {{baseUrl}}/adsweb/api/v1/patient/1

### Test Missing Token - Delete Dentist
DELETE {{baseUrl}}/adsweb/api/v1/dentist/1

### Test Missing Token - Delete Surgery
DELETE {{baseUrl}}/adsweb/api/v1/surgery/1

### Test Invalid Token - Get All Appointments
GET {{baseUrl}}/adsweb/api/v1/appointments
Authorization: Bearer invalid.token.here

### Test Invalid Token - Get All Patients
GET {{baseUrl}}/adsweb/api/v1/patients
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.invalid.token

### Test Invalid Token - Create Patient
POST {{baseUrl}}/adsweb/api/v1/patients
Content-Type: application/json
Authorization: Bearer invalidtoken123

{
	"firstName": "Test",
	"lastName": "User",
	"phoneNumber": "641-555-1234",
	"email": "test@example.com",
	"address": {
		"addressLine": "123 Main St",
		"city": "Fairfield",
		"state": "IA",
		"postalCode": "52557"
	},
	"dateOfBirth": "1990-01-01",
	"hasUnpaidBill": false
}

### Test Invalid Token - Delete Appointment
DELETE {{baseUrl}}/adsweb/api/v1/appointment/1
Authorization: Bearer invalidtoken123

### Public Endpoints - Register (no auth required)
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "newuser@example.com",
  "password": "Password123!",
  "role": "PATIENT"
}

### Public Endpoints - Login (no auth required)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
	"email": "newuser@example.com",
	"password": "Password123!"
}

### Test Expired/Invalid Refresh Token
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
	"refreshToken": "expired.refresh.token"
}
