@baseUrl = http://localhost:8081

### ========================================
### AUTHENTICATION ENDPOINTS
### ========================================

### Generic User Registration (Admin use)
# @name registerAdmin
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "admin@clinic.com",
  "password": "admin123",
  "role": "ADMIN"
}

### Login (Admin)
# @name loginAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@clinic.com",
  "password": "admin123"
}

###

@adminToken = {{loginAdmin.response.body.$.accessToken}}

### Refresh Token
POST {{baseUrl}}/api/auth/refresh
Authorization: Bearer {{adminToken}}

### ========================================
### PATIENT ENDPOINTS (Self-Registration)
### ========================================

### Patient Self-Registration (Creates User + Patient + Address)
# @name registerPatient
POST {{baseUrl}}/adsweb/api/v1/patients/register
Content-Type: application/json

{
  "email": "john.patient@clinic.com",
  "password": "patient123",
  "firstName": "John",
  "lastName": "Doe",
  "phoneNumber": "5155551234",
  "dateOfBirth": "1990-05-20",
  "addressLine": "123 Main St",
  "city": "Des Moines",
  "state": "IA",
  "postalCode": "50309"
}

###

@patientToken = {{registerPatient.response.body.$.accessToken}}

### Login as Patient (for subsequent requests)
# @name loginPatient
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "john.patient@clinic.com",
  "password": "patient123"
}

###

@patientToken2 = {{loginPatient.response.body.$.accessToken}}

### List All Patients (Requires ROLE_ADMIN or ROLE_OFFICE_MANAGER)
GET {{baseUrl}}/adsweb/api/v1/patients
Authorization: Bearer {{adminToken}}

### Get Patient By Id (Accessible by Patient, Admin, Office Manager)
GET {{baseUrl}}/adsweb/api/v1/patients/1
Authorization: Bearer {{patientToken2}}

### Create Patient (Admin/Office Manager use - without password)
# @name createPatientAdmin
POST {{baseUrl}}/adsweb/api/v1/patients
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "firstName": "Robert",
  "lastName": "Johnson",
  "phoneNumber": "5155558888",
  "email": "robert.johnson@clinic.com",
  "dateOfBirth": "1985-07-22",
  "hasUnpaidBill": true,
  "address": {
    "addressLine": "321 Maple Dr",
    "city": "Waterloo",
    "state": "IA",
    "postalCode": "50701"
  }
}

### Update Patient (Patient can update own, Admin can update any)
PUT {{baseUrl}}/adsweb/api/v1/patient/1
Authorization: Bearer {{patientToken2}}
Content-Type: application/json

{
  "firstName": "John",
  "lastName": "Doe Updated",
  "phoneNumber": "5155558888",
  "email": "john.patient@clinic.com",
  "dateOfBirth": "1990-05-20",
  "hasUnpaidBill": false,
  "address": {
    "addressLine": "123 Main St Updated",
    "city": "Fairfield",
    "state": "IA",
    "postalCode": "52557"
  }
}

### Delete Patient (Admin only)
DELETE {{baseUrl}}/adsweb/api/v1/patient/11
Authorization: Bearer {{adminToken}}

### Search Patients
GET {{baseUrl}}/adsweb/api/v1/patient/search/john
Authorization: Bearer {{adminToken}}

### ========================================
### DENTIST ENDPOINTS (Self-Registration)
### ========================================

### Dentist Self-Registration (Creates User + Dentist)
# @name registerDentist
POST {{baseUrl}}/adsweb/api/v1/dentists/register
Content-Type: application/json

{
  "email": "dr.smith@clinic.com",
  "password": "dentist123",
  "firstName": "Dr.",
  "lastName": "Smith",
  "phoneNumber": "5155552222",
  "specialization": "Orthodontist"
}

###

@dentistToken = {{registerDentist.response.body.$.accessToken}}

### Login as Dentist (for subsequent requests)
# @name loginDentist
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "dr.smith@clinic.com",
  "password": "dentist123"
}

###

@dentistToken2 = {{loginDentist.response.body.$.accessToken}}

### List All Dentists (Accessible by all authenticated users)
GET {{baseUrl}}/adsweb/api/v1/dentists
Authorization: Bearer {{dentistToken2}}

### Get Dentist By Id
GET {{baseUrl}}/adsweb/api/v1/dentists/1
Authorization: Bearer {{dentistToken2}}

### Create Dentist (Admin only - without password)
# @name createDentistAdmin
POST {{baseUrl}}/adsweb/api/v1/dentists
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "firstName": "Dr.",
  "lastName": "Johnson",
  "phoneNumber": "5155553333",
  "email": "dr.johnson.admin@clinic.com",
  "specialization": "General Dentistry"
}

### Update Dentist (Dentist can update own, Admin can update any)
PUT {{baseUrl}}/adsweb/api/v1/dentist/1
Authorization: Bearer {{dentistToken2}}
Content-Type: application/json

{
  "firstName": "Dr.",
  "lastName": "Smith Updated",
  "phoneNumber": "5155552222",
  "email": "dr.smith.updated@clinic.com",
  "specialization": "Pediatric Dentistry"
}

### Delete Dentist (Admin only)
DELETE {{baseUrl}}/adsweb/api/v1/dentist/1
Authorization: Bearer {{adminToken}}

### Search Dentists
GET {{baseUrl}}/adsweb/api/v1/dentist/search/smith
Authorization: Bearer {{dentistToken2}}

### ========================================
### ROLE-BASED ACCESS CONTROL TESTS
### ========================================

### Test: Patient tries to create another patient (Should fail - forbidden)
POST {{baseUrl}}/adsweb/api/v1/patients
Authorization: Bearer {{patientToken2}}
Content-Type: application/json

{
  "firstName": "Unauthorized",
  "lastName": "Patient",
  "phoneNumber": "5155555555",
  "email": "unauthorized@example.com",
  "dateOfBirth": "1995-01-01",
  "hasUnpaidBill": false,
  "address": {
    "addressLine": "Test",
    "city": "Test",
    "state": "IA",
    "postalCode": "50000"
  }
}

### Test: Dentist tries to delete a patient (Should fail - forbidden)
DELETE {{baseUrl}}/adsweb/api/v1/patient/1
Authorization: Bearer {{dentistToken2}}

### Test: Request without token (Should fail - unauthorized)
GET {{baseUrl}}/adsweb/api/v1/patients

### ========================================
### GRAPHQL EXAMPLES (with JWT)
### ========================================

### GraphQL - List Patients
POST {{baseUrl}}/graphql
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
	"query": "query { patients { id firstName lastName email dateOfBirth hasUnpaidBill address { city state postalCode } } }"
}

### GraphQL - Create Patient
# @name createPatientGraphql
POST {{baseUrl}}/graphql
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
	"query": "mutation($input: PatientInput!) { createPatient(input: $input) { id firstName lastName email dateOfBirth hasUnpaidBill address { id city state } } }",
	"variables": {
		"input": {
			"firstName": "Alice",
			"lastName": "Brown",
			"phoneNumber": "5153332222",
			"email": "alice.brown@example.com",
			"dateOfBirth": "1992-10-11",
			"hasUnpaidBill": false,
			"address": {
				"addressLine": "400 Elm St",
				"city": "Fairfield",
				"state": "IA",
				"postalCode": "52557"
			}
		}
	}
}

### GraphQL - Get Patient By Id
### NOTE: Run "GraphQL - Create Patient" first to populate {{graphqlPatientId}}
### If {{graphqlPatientId}} is undefined, this will return an INTERNAL_ERROR
@graphqlPatientId = {{createPatientGraphql.response.body.$.data.createPatient.id}}
POST {{baseUrl}}/graphql
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
	"query": "query($id: ID!) { patientById(id: $id) { id firstName lastName email address { addressLine city state postalCode } } }",
	"variables": {
		"id": "{{graphqlPatientId}}"
	}
}

### GraphQL - Update Patient
### NOTE: Run "GraphQL - Create Patient" first to populate {{graphqlPatientId}}
### If {{graphqlPatientId}} is undefined, this will return an INTERNAL_ERROR
POST {{baseUrl}}/graphql
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
	"query": "mutation($id: ID!, $input: PatientInput!) { updatePatient(id: $id, input: $input) { id firstName lastName email hasUnpaidBill address { city state } } }",
	"variables": {
		"id": "{{graphqlPatientId}}",
		"input": {
			"firstName": "Alice",
			"lastName": "Brown Updated",
			"phoneNumber": "5153334444",
			"email": "alice.brown.updated@example.com",
			"dateOfBirth": "1992-10-11",
			"hasUnpaidBill": true,
			"address": {
				"addressLine": "900 Cedar Dr",
				"city": "Des Moines",
				"state": "IA",
				"postalCode": "50310"
			}
		}
	}
}

### GraphQL - Delete Patient
### NOTE: Run "GraphQL - Create Patient" first to populate {{graphqlPatientId}}
### If {{graphqlPatientId}} is undefined, this will return an INTERNAL_ERROR
POST {{baseUrl}}/graphql
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
	"query": "mutation($id: ID!) { deletePatient(id: $id) }",
	"variables": {
		"id": "{{graphqlPatientId}}"
	}
}

### GraphQL - List Addresses
POST {{baseUrl}}/graphql
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
	"query": "query { addresses { id addressLine city state postalCode patient { id firstName lastName } } }"
}

### ========================================
### HOME/HEALTH ENDPOINTS
### ========================================

### Get Application Info
GET {{baseUrl}}/

