Authorization: Bearer {{accessToken}}

### Get All Addresses
GET {{baseUrl}}/adsweb/api/v1/addresses
Authorization: Bearer {{accessToken}}

### Search Addresses
GET {{baseUrl}}/adsweb/api/v1/address/search/fairfield
Authorization: Bearer {{accessToken}}

### Delete Address (replace id)
DELETE {{baseUrl}}/adsweb/api/v1/address/1
Authorization: Bearer {{accessToken}}

### Update Appointment (replace id)
PUT {{baseUrl}}/adsweb/api/v1/appointment/1
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
	"patientId": 1,
	"dentistId": 1,
	"surgeryId": 1,
	"appointmentDate": "2026-05-11",
	"appointmentTime": "10:30"
}

### Get Appointment By Id (replace id)
GET {{baseUrl}}/adsweb/api/v1/appointments/11
Authorization: Bearer {{accessToken}}

### Get Appointments By Patient (replace id)
GET {{baseUrl}}/adsweb/api/v1/appointments/patient/1
Authorization: Bearer {{accessToken}}

### Get Upcoming Appointments By Patient (replace id)
GET {{baseUrl}}/adsweb/api/v1/appointments/patient/1/upcoming
Authorization: Bearer {{accessToken}}

### Get Appointments By Dentist (replace id)
GET {{baseUrl}}/adsweb/api/v1/appointments/dentist/1
Authorization: Bearer {{accessToken}}

### Get Upcoming Appointments By Dentist (replace id)
GET {{baseUrl}}/adsweb/api/v1/appointments/dentist/1/upcoming
Authorization: Bearer {{accessToken}}

### Get Appointments By Surgery (replace id)
GET {{baseUrl}}/adsweb/api/v1/appointments/surgery/1
Authorization: Bearer {{accessToken}}

### Search Appointments
GET {{baseUrl}}/adsweb/api/v1/appointments/search?patientSearchString=jane&dentistSearchString=andrew&surgerySearchString=fairfield
Authorization: Bearer {{accessToken}}

### Cancel Appointment (replace id)
POST {{baseUrl}}/adsweb/api/v1/appointment/1/cancel
Authorization: Bearer {{accessToken}}

### Reschedule Appointment (replace id)
PUT {{baseUrl}}/adsweb/api/v1/appointment/11/reschedule
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
	"appointmentDate": "2026-05-12",
	"appointmentTime": "11:00"
}

### Delete Appointment (replace id)
DELETE {{baseUrl}}/adsweb/api/v1/appointment/19
Authorization: Bearer {{accessToken}}

### Refresh Token
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
	"refreshToken": "{{loginOfficeManager.response.body.$.refreshToken}}"
}
