@baseUrl = http://localhost:8081

### ========================================
### PATIENT DEMO
### ========================================

### Patient Self-Registration (creates User + Patient + Address)
# @name registerPatient
POST {{baseUrl}}/adsweb/api/v1/patients/register
Content-Type: application/json

{
  "email": "jane.patient@clinic.com",
  "password": "patient123",
  "firstName": "Jane",
  "lastName": "Patient",
  "phoneNumber": "5155556000",
  "dateOfBirth": "1991-03-18",
  "addressLine": "88 Oak Dr",
  "city": "Fairfield",
  "state": "IA",
  "postalCode": "52557"
}

###
@patientToken = {{registerPatient.response.body.$.accessToken}}

### Login Patient (if already registered)
# @name loginPatient
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "jane.patient@clinic.com",
  "password": "patient123"
}

###
@patientToken2 = {{loginPatient.response.body.$.accessToken}}

### List Dentists (pick a dentistId for appointment request)
GET {{baseUrl}}/adsweb/api/v1/dentists
Authorization: Bearer {{patientToken2}}

### List Surgeries (pick a surgeryId for appointment request)
GET {{baseUrl}}/adsweb/api/v1/surgeries
Authorization: Bearer {{patientToken2}}

### Set these after checking the lists above
@dentistId = 1
@surgeryId = 1
@patientId = 1

### Request Appointment (online)
# @name requestAppointment
POST {{baseUrl}}/adsweb/api/v1/appointments
Authorization: Bearer {{patientToken2}}
Content-Type: application/json

{
  "patientId": {{patientId}},
  "dentistId": {{dentistId}},
  "surgeryId": {{surgeryId}},
  "appointmentDate": "2026-05-12",
  "appointmentTime": "14:00"
}

###
@appointmentId = {{requestAppointment.response.body.$.id}}

### View My Appointments
GET {{baseUrl}}/adsweb/api/v1/appointments/patient/{{patientId}}
Authorization: Bearer {{patientToken2}}

### View Appointment Details
GET {{baseUrl}}/adsweb/api/v1/appointments/{{appointmentId}}
Authorization: Bearer {{patientToken2}}

### Request Appointment Change (Reschedule)
PUT {{baseUrl}}/adsweb/api/v1/appointment/{{appointmentId}}/reschedule
Authorization: Bearer {{patientToken2}}
Content-Type: application/json

{
  "newAppointmentDate": "2026-05-20",
  "newAppointmentTime": "09:00",
  "reason": "Need a morning slot"
}

### Request Appointment Cancellation
POST {{baseUrl}}/adsweb/api/v1/appointment/{{appointmentId}}/cancel
Authorization: Bearer {{patientToken2}}
