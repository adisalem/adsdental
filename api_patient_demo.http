@baseUrl = http://localhost:8081

### Register Patient (run once)
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "patient@example.com",
  "password": "Password123!",
  "role": "PATIENT"
}

### Login Patient (copy accessToken from response)
# @name loginPatient
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
	"email": "patient@example.com",
	"password": "Password123!"
}
###

@accessToken = {{loginPatient.response.body.$.accessToken}}

### Get All Appointments (Patient view)
GET {{baseUrl}}/adsweb/api/v1/appointments
Authorization: Bearer {{accessToken}}

### Get Appointments By Patient (replace id)
GET {{baseUrl}}/adsweb/api/v1/appointments/patient/1
Authorization: Bearer {{accessToken}}

### Get Upcoming Appointments By Patient (replace id)
GET {{baseUrl}}/adsweb/api/v1/appointments/patient/1/upcoming
Authorization: Bearer {{accessToken}}

### Get Appointment By Id (replace id)
GET {{baseUrl}}/adsweb/api/v1/appointments/11
Authorization: Bearer {{accessToken}}

### Create Appointment (replace ids)
POST {{baseUrl}}/adsweb/api/v1/appointments
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
	"patientId": 1,
	"dentistId": 1,
	"surgeryId": 1,
	"appointmentDate": "2026-06-15",
	"appointmentTime": "14:00"
}

### Update Appointment (replace id)
PUT {{baseUrl}}/adsweb/api/v1/appointment/1
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
	"patientId": 1,
	"dentistId": 1,
	"surgeryId": 1,
	"appointmentDate": "2026-06-16",
	"appointmentTime": "15:00"
}

### Reschedule Appointment (replace id)
PUT {{baseUrl}}/adsweb/api/v1/appointment/1/reschedule
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
	"appointmentDate": "2026-06-17",
	"appointmentTime": "16:00"
}

### Cancel Appointment (replace id)
POST {{baseUrl}}/adsweb/api/v1/appointment/1/cancel
Authorization: Bearer {{accessToken}}

### Delete Appointment (replace id)
DELETE {{baseUrl}}/adsweb/api/v1/appointment/1
Authorization: Bearer {{accessToken}}

### Get All Dentists
GET {{baseUrl}}/adsweb/api/v1/dentists
Authorization: Bearer {{accessToken}}

### Search Dentists
GET {{baseUrl}}/adsweb/api/v1/dentist/search/andrew
Authorization: Bearer {{accessToken}}

### Get All Surgeries
GET {{baseUrl}}/adsweb/api/v1/surgeries
Authorization: Bearer {{accessToken}}

### Search Surgeries
GET {{baseUrl}}/adsweb/api/v1/surgery/search/fairfield
Authorization: Bearer {{accessToken}}

### Get All Addresses
GET {{baseUrl}}/adsweb/api/v1/addresses
Authorization: Bearer {{accessToken}}

### Get Address By Id (replace id)
GET {{baseUrl}}/adsweb/api/v1/addresses/1
Authorization: Bearer {{accessToken}}

### Search Addresses
GET {{baseUrl}}/adsweb/api/v1/address/search/fairfield
Authorization: Bearer {{accessToken}}

### Refresh Token
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
	"refreshToken": "{{loginPatient.response.body.$.refreshToken}}"
}
