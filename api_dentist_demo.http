@baseUrl = http://localhost:8081

### ========================================
### DENTIST DEMO
### ========================================

### Dentist Self-Registration (first time only)
# @name registerDentist
POST {{baseUrl}}/adsweb/api/v1/dentists/register
Content-Type: application/json

{
  "email": "dr.lee@clinic.com",
  "password": "dentist123",
  "firstName": "Dr.",
  "lastName": "Lee",
  "phoneNumber": "5155557000",
  "specialization": "Orthodontist"
}

### Login Dentist
# @name loginDentist
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "dr.lee@clinic.com",
  "password": "dentist123"
}

###
@dentistToken = {{loginDentist.response.body.$.accessToken}}

### Set dentistId if known (from list below)
@dentistId = 1

### View All Dentists
GET {{baseUrl}}/adsweb/api/v1/dentists
Authorization: Bearer {{dentistToken}}

### View My Appointments
GET {{baseUrl}}/adsweb/api/v1/appointments/dentist/{{dentistId}}
Authorization: Bearer {{dentistToken}}

### View Upcoming Appointments
GET {{baseUrl}}/adsweb/api/v1/appointments/dentist/{{dentistId}}/upcoming
Authorization: Bearer {{dentistToken}}

### View Appointment Details (requires appointmentId)
@appointmentId = 1
GET {{baseUrl}}/adsweb/api/v1/appointments/{{appointmentId}}
Authorization: Bearer {{dentistToken}}

### View Surgery Details (optional)
@SurgeryId = 1
GET {{baseUrl}}/adsweb/api/v1/surgeries/{{SurgeryId}}
Authorization: Bearer {{dentistToken}}
